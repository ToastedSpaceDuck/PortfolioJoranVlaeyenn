---
const { title, description } = Astro.props;
---

<div class="expect__item">
    <h3>{title}</h3>
    <p>
        {description}
    </p>
</div>

<style>
    .expect__item h3 {
        font-family: "Space Mono", monospace;
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 14px;
        color: white;
    }

    .expect__item p {
        font-size: 15px;
        line-height: 1.75;
        color: #edf4fa;
    }
</style>
