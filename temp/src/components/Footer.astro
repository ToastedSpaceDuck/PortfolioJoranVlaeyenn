  .footer-inner {
    display: flex;
    gap: 120px;
    justify-content: center;
    align-items: center;
    z-index: 2;
  }

  .footer-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: center;
    width: 250px;
  }

  .footer-item .label {
    font-family: "Space Mono", monospace;
    font-size: 14px;
    color: #8a8f98;
  }

  .footer-item .value {
    font-size: 16px;
    color: white;
    text-decoration: none;
  }

  .footer-item .link:hover {
    opacity: 0.7;
    transition: 0.3s ease;
  }

  @media (max-width: 1024px) {
    .footer-inner {
      gap: 60px;
    }
  }

  @media (max-width: 768px) {
    .footer {
      margin: 60px 16px;
    }
    .footer-inner {
