<style>
  .footer {
    background: #0f1013;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 120px;
  }

  .footer-fade {
    top: 0;
    left: 0;
    width: 100%;
    height: 200px;
    background: linear-gradient(to top, #0f1013, rgba(5, 7, 13, 0));
