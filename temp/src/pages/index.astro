---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import CardSection from "../components/CardSection.astro";
---

<BaseLayout title="Joran Vlaeyen" activePage="home">
  <!-- HERO -->
  <header class="hero">
    <img src="/public/Background.jpeg" alt="" />
    <div class="hero-fade"></div>
    <div class="hero-content">
      <div class="hero-inner">
        <h1>
          Design isn't something you <br />
          finish quickly it's <br />
          something you get right.
        </h1>
        <p>
          I focus on <strong>understanding problems</strong>, making deliberate
          decisions and designing
          <strong>solutions</strong> that actually <strong>work</strong>.
        </p>
        <div class="hero-tags">
          <span>Joran Vlaeyen</span>
          <span>UI/UX Design</span>
          <span>Design Systems</span>
          <span>User analysis</span>
        </div>
        <a href="/about"><button>About me →</button></a>
      </div>
    </div>
  </header>

  <!-- CASE STUDIES -->
  <CardSection title="In-depth case studies">
    <Card
      title="Graduate thesis"
      description="An e-commerce template created by a software platform specializing in time management for businesses in the beauty industry, including UX testing based on information about products, navigation and the purchasing process"
      image="/public/graduats.png"
      topcolor="#191F31"
      bottomcolor="#0F1013"
    />

    <Card
      title="Coming soon"
      description="Since I just graduated, I don't have much experience yet, so I'm currently working on projects. Once they're finished and fully developed, I'll post them here"
      image="/public/empty.png"
      topcolor="#1F2228"
      bottomcolor="#13161E"
    />
  </CardSection>

  <CardSection title=' "Unofficial" Projects'>
    <Card
      title="Koyle"
      description="A complete redesign of a Belgian cover band's website, including UX testing based on the band's booking process."
      image="/public/Koyle.png"
      topcolor="#191F31"
      bottomcolor="#0F1013"
      size="small"
    />

    <Card
      title="Personal portfolio"
      description="Since I just graduated, I don't have much experience yet, so I'm currently working on projects. Once they're finished and fully developed, I'll post them here"
      image="/public/empty.png"
      topcolor="#1F2228"
      bottomcolor="#13161E"
      size="small"
    />

       <Card
      title="Personal portfolio"
      description="Since I just graduated, I don't have much experience yet, so I'm currently working on projects. Once they're finished and fully developed, I'll post them here"
      image="/public/emptyGrey.png"
      topcolor="#191F31"
      bottomcolor="#0F1013"
      size="small"
    />
  </CardSection>
</BaseLayout>

<style>
  /* ── HERO ── */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .hero > img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      #05070d 0%,
      #05070d77 60%,
      #05070d 100%
    );
  }

  .hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
  }

  .hero-inner {
    max-width: 1400px;
    padding: 0 120px 80px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero-inner h1 {
    font-family: "Space Mono", monospace;
    font-size: 40px;
    line-height: 1.15;
    letter-spacing: -1px;
    margin-bottom: 24px;
  }

  .hero-inner p {
    font-size: 24px;
    color: #b8b8b8;
    max-width: 620px;
    margin-bottom: 24px;
    line-height: 1.5;
  }

  .hero-inner p strong {
    color: white;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0 16px;
    font-family: "Space Mono", monospace;
    font-size: 16px;
    color: #8a8f98;
    letter-spacing: 0.02em;
    margin-bottom: 32px;
  }

  .hero-tags span + span::before {
    content: "· ";
    margin-right: 4px;
  }

  .hero-inner button {
    align-self: flex-start;
    background: transparent;
    font-size: 20px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: white;
    padding: 16px 28px;
    cursor: pointer;
    transition:
      background-color 0.35s ease,
      color 0.35s ease;
  }

  .hero-inner button:hover {
    background: #edf4fa;
    color: #0f1013;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .hero-inner {
      padding: 0 48px 64px;
    }
    .hero-inner h1 {
      font-size: 32px;
    }
    .hero-inner p {
      font-size: 18px;
    }
    .projects {
      padding: 60px 48px;
    }
    .projects-inner {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .card-top {
      height: 240px;
    }
    .project-inner.three {
      grid-template-columns: repeat(2, 1fr);
    }
    .project-inner.three .project-card:last-child {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .hero-inner {
      padding: 0 24px 40px;
    }
    .hero-inner h1 {
      font-size: 24px;
      letter-spacing: -0.5px;
      margin-bottom: 16px;
    }
    .hero-inner p {
      font-size: 16px;
      margin-bottom: 16px;
    }
    .hero-tags {
      font-size: 13px;
      margin-bottom: 24px;
    }
    .hero-inner button {
      font-size: 16px;
      padding: 12px 22px;
    }
    .projects {
      padding: 48px 24px;
    }
    .projects-inner {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .card-top {
      height: 200px;
    }
    .card-title {
      font-size: 16px;
    }
    .card-text {
      font-size: 13px;
    }
    .project-inner.three {
      grid-template-columns: 1fr;
    }
    .project-inner.three .project-card:last-child {
      grid-column: span 1;
    }
    .project-card.small .card-top {
      height: 160px;
    }
  }
</style>
